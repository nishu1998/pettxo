rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.adminRole in ["superAdmin", "customerSupportAdmin", "financeAdmin"];
    }

    function isSupportedImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    function isMaxFiveMb() {
      return request.resource.size <= 5 * 1024 * 1024;
    }

    function isMaxTenMb() {
      return request.resource.size <= 10 * 1024 * 1024;
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) &&
        isSupportedImage() &&
        isMaxFiveMb();
    }

    match /users/{userId}/services/{serviceId}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) &&
        isSupportedImage() &&
        isMaxFiveMb();
    }

    match /disputes/{disputeId}/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) &&
        isSupportedImage() &&
        isMaxFiveMb();
    }

    match /socialPosts/{userId}/{postId}/{folder}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) &&
        folder in ['images', 'thumbs'] &&
        isSupportedImage() &&
        isMaxFiveMb();
    }

    match /providerVerification/{userId}/identity/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) &&
        isSupportedImage() &&
        isMaxTenMb();
    }

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
