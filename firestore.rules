rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole in [
          "superAdmin",
          "customerSupportAdmin",
          "financeAdmin"
        ];
    }

    function canModerateSocialContent() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole in [
            "superAdmin",
            "customerSupportAdmin"
          ] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canModerateReports == true
        );
    }

    function canMonitorChats() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole in [
          "superAdmin",
          "customerSupportAdmin"
        ];
    }

    function canReviewProviderVerification() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole in [
          "superAdmin",
          "customerSupportAdmin"
        ];
    }

    function existingOwnerId() {
      return resource.data.ownerUserId;
    }

    function chatParticipant(chatData) {
      return signedIn() &&
        request.auth.uid in chatData.participantIds;
    }

    function directUserChatParticipantIdsValid() {
      return request.resource.data.participantIds is list &&
        request.resource.data.participantIds.size() == 2 &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds[0] is string &&
        request.resource.data.participantIds[1] is string &&
        request.resource.data.participantIds[0] != request.resource.data.participantIds[1];
    }

    function safeDirectUserChatCreate(chatId) {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'chatType',
        'customerId',
        'providerId',
        'participantIds',
        'participantSnapshots',
        'customerName',
        'customerPhotoUrl',
        'providerName',
        'providerPhotoUrl',
        'sourceServiceIds',
        'lastServiceId',
        'lastServiceTitle',
        'lastServiceImageUrl',
        'lastMessage',
        'lastMessageAt',
        'lastSenderId',
        'unreadCountCustomer',
        'unreadCountProvider',
        'customerLastReadAt',
        'providerLastReadAt',
        'status',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.chatType == 'directUser' &&
      directUserChatParticipantIdsValid() &&
      request.resource.data.customerId == request.resource.data.participantIds[0] &&
      request.resource.data.providerId == request.resource.data.participantIds[1] &&
      chatId == ('direct_' + request.resource.data.participantIds[0] + '_' + request.resource.data.participantIds[1]) &&
      request.resource.data.participantSnapshots is list &&
      request.resource.data.participantSnapshots.size() == 2 &&
      request.resource.data.sourceServiceIds is list &&
      request.resource.data.sourceServiceIds.size() == 0 &&
      request.resource.data.lastServiceId == '' &&
      request.resource.data.lastServiceTitle == '' &&
      request.resource.data.lastServiceImageUrl == '' &&
      request.resource.data.lastMessage == '' &&
      request.resource.data.lastSenderId == '' &&
      request.resource.data.unreadCountCustomer == 0 &&
      request.resource.data.unreadCountProvider == 0 &&
      request.resource.data.customerLastReadAt == null &&
      request.resource.data.providerLastReadAt == null &&
      request.resource.data.status == 'active' &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time;
    }

    function safeProviderServiceChatCreate(chatId) {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'chatType',
        'customerId',
        'providerId',
        'participantIds',
        'participantSnapshots',
        'customerName',
        'customerPhotoUrl',
        'providerName',
        'providerPhotoUrl',
        'sourceServiceIds',
        'lastServiceId',
        'lastServiceTitle',
        'lastServiceImageUrl',
        'lastMessage',
        'lastMessageAt',
        'lastSenderId',
        'unreadCountCustomer',
        'unreadCountProvider',
        'customerLastReadAt',
        'providerLastReadAt',
        'status',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.chatType == 'providerService' &&
      directUserChatParticipantIdsValid() &&
      request.resource.data.customerId == request.auth.uid &&
      request.resource.data.customerId == request.resource.data.participantIds[0] &&
      request.resource.data.providerId == request.resource.data.participantIds[1] &&
      request.resource.data.customerId != request.resource.data.providerId &&
      (
        chatId == (request.resource.data.customerId + '_' + request.resource.data.providerId) ||
        chatId == (request.resource.data.providerId + '_' + request.resource.data.customerId)
      ) &&
      request.resource.data.participantSnapshots is list &&
      request.resource.data.participantSnapshots.size() == 2 &&
      request.resource.data.sourceServiceIds is list &&
      request.resource.data.sourceServiceIds.size() == 1 &&
      request.resource.data.lastServiceId is string &&
      request.resource.data.lastServiceId == request.resource.data.sourceServiceIds[0] &&
      request.resource.data.lastServiceTitle is string &&
      request.resource.data.lastServiceImageUrl is string &&
      request.resource.data.lastMessage == '' &&
      request.resource.data.lastSenderId == '' &&
      request.resource.data.unreadCountCustomer == 0 &&
      request.resource.data.unreadCountProvider == 0 &&
      request.resource.data.customerLastReadAt == null &&
      request.resource.data.providerLastReadAt == null &&
      request.resource.data.status == 'active' &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time &&
      exists(/databases/$(database)/documents/services/$(request.resource.data.lastServiceId)) &&
      get(/databases/$(database)/documents/services/$(request.resource.data.lastServiceId)).data.ownerUserId == request.resource.data.providerId &&
      get(/databases/$(database)/documents/services/$(request.resource.data.lastServiceId)).data.isDeleted != true &&
      get(/databases/$(database)/documents/services/$(request.resource.data.lastServiceId)).data.isVisibleToMarketplace == true;
    }

    function safeUserOwnerCreate() {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'uid',
        'role',
        'name',
        'username',
        'usernameLowercase',
        'state',
        'city',
        'profileImage',
        'bio',
        'createdAt'
      ]) &&
      request.resource.data.createdAt == request.time;
    }

    function safeServiceOwnerUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'title',
        'titleLowercase',
        'animalType',
        'animalTypeLowercase',
        'category',
        'categoryLowercase',
        'description',
        'privateNotes',
        'pricePerSession',
        'sessionDurationMinutes',
        'capacity',
        'availableDays',
        'startMinutes',
        'endMinutes',
        'sameForAllDays',
        'serviceRadiusKm',
        'serviceType',
        'location',
        'photoUrls',
        'primaryPhotoUrl',
        'status',
        'isActive',
        'isDeleted',
        'isPaused',
        'isVisibleToMarketplace',
        'updatedAt',
        'removedAt'
      ]);
    }

    function safeServiceOwnerCreate() {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'ownerUserId',
        'ownerName',
        'ownerUsername',
        'ownerPhotoUrl',
        'ownerSnapshot',
        'title',
        'titleLowercase',
        'animalType',
        'animalTypeLowercase',
        'category',
        'categoryLowercase',
        'description',
        'privateNotes',
        'pricePerSession',
        'currency',
        'sessionDurationMinutes',
        'capacity',
        'availableDays',
        'startMinutes',
        'endMinutes',
        'sameForAllDays',
        'serviceType',
        'location',
        'photoUrls',
        'primaryPhotoUrl',
        'status',
        'isActive',
        'isDeleted',
        'isPaused',
        'moderationStatus',
        'isVisibleToMarketplace',
        'providerVerificationStatus',
        'providerVerificationGraceEndsAt',
        'isPausedByVerification',
        'pauseReason',
        'createdAt',
        'updatedAt',
        'publishedAt'
      ]) &&
      request.resource.data.providerVerificationStatus in [
        'pending',
        'approved',
        'rejected',
        'notSubmitted'
      ] &&
      (
        !request.resource.data.keys().hasAny(['providerVerificationGraceEndsAt']) ||
        request.resource.data.providerVerificationGraceEndsAt == null ||
        request.resource.data.providerVerificationGraceEndsAt is timestamp
      ) &&
      request.resource.data.isPausedByVerification == false &&
      request.resource.data.pauseReason is string &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time &&
      request.resource.data.publishedAt == request.time;
    }

    function providerVerificationDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/providerVerification/main);
    }

    function providerBankDetailsDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/providerBankDetails/main);
    }

    function safeServiceVerificationCreate(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/providerVerification/main) &&
        exists(/databases/$(database)/documents/users/$(userId)/providerBankDetails/main) &&
        get(/databases/$(database)/documents/users/$(userId)).data.deletionRequested != true &&
        request.resource.data.providerVerificationStatus ==
          providerVerificationDoc(userId).data.status &&
        request.resource.data.isPausedByVerification == false &&
        request.resource.data.pauseReason == '' &&
        (
          providerVerificationDoc(userId).data.status == 'approved' ||
          request.resource.data.providerVerificationGraceEndsAt is timestamp
        );
    }

    function safeUserOwnerUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name',
        'username',
        'usernameLowercase',
        'bio',
        'profileType',
        'profileImage',
        'city',
        'state',
        'country',
        'location',
        'address',
        'email',
        'phone',
        'mobileNumber',
        'updatedAt'
      ]) &&
      (
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['email']) ||
        !request.resource.data.keys().hasAny(['email'])
      ) &&
      (
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['phone']) ||
        !request.resource.data.keys().hasAny(['phone'])
      ) &&
      (
        !request.resource.data.diff(resource.data).changedKeys().hasAny(['mobileNumber']) ||
        !request.resource.data.keys().hasAny(['mobileNumber'])
      ) &&
      request.resource.data.updatedAt == request.time;
    }

    function safeUserPrivateOwnerWrite(userId) {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'phone',
        'mobileNumber',
        'createdAt',
        'updatedAt',
        'deletionRequestedAt',
        'deletionRequestStatus'
      ]) &&
      request.resource.data.uid == userId &&
      (
        !request.resource.data.keys().hasAny(['email']) ||
        request.resource.data.email is string
      ) &&
      (
        !request.resource.data.keys().hasAny(['phone']) ||
        request.resource.data.phone is string
      ) &&
      (
        !request.resource.data.keys().hasAny(['mobileNumber']) ||
        request.resource.data.mobileNumber is string
      ) &&
      (
        !request.resource.data.keys().hasAny(['deletionRequestedAt']) ||
        request.resource.data.deletionRequestedAt == null
      ) &&
      (
        !request.resource.data.keys().hasAny(['deletionRequestStatus']) ||
        request.resource.data.deletionRequestStatus == null
      ) &&
      request.resource.data.updatedAt == request.time;
    }

    function safeUserPrivateOwnerCreate(userId) {
      return safeUserPrivateOwnerWrite(userId) &&
        request.resource.data.createdAt == request.time;
    }

    function safeUserPrivateOwnerUpdate(userId) {
      return safeUserPrivateOwnerWrite(userId) &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function safeSocialPostCreate() {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'id',
        'authorId',
        'authorType',
        'authorDisplayName',
        'authorUsername',
        'authorPhotoUrl',
        'authorCategoryLabel',
        'authorCity',
        'authorState',
        'isAdminPost',
        'adminPriorityBoost',
        'recentEngagementScore',
        'imageUrls',
        'thumbnailUrls',
        'imageAspectRatio',
        'caption',
        'hashtags',
        'likeCount',
        'commentCount',
        'shareCount',
        'saveCount',
        'reportCount',
        'visibilityStatus',
        'moderationStatus',
        'moderationReason',
        'moderatedBy',
        'moderatedAt',
        'lastReportedAt',
        'createdAtEpoch',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.id == request.resource.id &&
      request.resource.data.authorId == request.auth.uid &&
      request.resource.data.authorType == 'user' &&
      request.resource.data.isAdminPost == false &&
      request.resource.data.adminPriorityBoost == 0 &&
      request.resource.data.recentEngagementScore == 0 &&
      request.resource.data.imageUrls.size() > 0 &&
      request.resource.data.imageUrls.size() <= 5 &&
      request.resource.data.thumbnailUrls.size() == request.resource.data.imageUrls.size() &&
      request.resource.data.imageAspectRatio in ['square', 'portrait', 'landscape'] &&
      request.resource.data.likeCount == 0 &&
      request.resource.data.commentCount == 0 &&
      request.resource.data.shareCount == 0 &&
      request.resource.data.saveCount == 0 &&
      request.resource.data.reportCount == 0 &&
      request.resource.data.visibilityStatus == 'visible' &&
      request.resource.data.moderationStatus == 'approved' &&
      request.resource.data.moderationReason == '' &&
      request.resource.data.moderatedBy == '' &&
      request.resource.data.moderatedAt == null &&
      request.resource.data.lastReportedAt == null &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time;
    }

    function likeDocPath(postId) {
      return /databases/$(database)/documents/socialPosts/$(postId)/likes/$(request.auth.uid);
    }

    function reportDocPath(postId) {
      return /databases/$(database)/documents/socialPosts/$(postId)/reports/$(request.auth.uid);
    }

    function safeSocialPostCommentCounterUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'commentCount'
      ]) &&
      resource.data.visibilityStatus == 'visible' &&
      resource.data.moderationStatus == 'approved' &&
      request.resource.data.commentCount >= 0 &&
      (
        request.resource.data.commentCount == resource.data.commentCount + 1 ||
        request.resource.data.commentCount == resource.data.commentCount - 1
      );
    }

    function safeSocialPostShareCounterUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'shareCount'
      ]) &&
      resource.data.visibilityStatus == 'visible' &&
      resource.data.moderationStatus == 'approved' &&
      request.resource.data.shareCount == resource.data.shareCount + 1;
    }

    function safeSocialPostSoftDelete() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'visibilityStatus',
        'updatedAt'
      ]) &&
      resource.data.authorId == request.auth.uid &&
      request.resource.data.visibilityStatus == 'deleted' &&
      request.resource.data.updatedAt == request.time;
    }

    function safeSocialPostLikeCounterUpdate(postId) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'likeCount'
      ]) &&
      resource.data.visibilityStatus == 'visible' &&
      resource.data.moderationStatus == 'approved' &&
      request.resource.data.likeCount >= 0 &&
      (
        (
          request.resource.data.likeCount == resource.data.likeCount + 1 &&
          !exists(likeDocPath(postId)) &&
          existsAfter(likeDocPath(postId))
        ) ||
        (
          request.resource.data.likeCount == resource.data.likeCount - 1 &&
          exists(likeDocPath(postId)) &&
          !existsAfter(likeDocPath(postId))
        )
      );
    }

    function safeSocialPostReportCounterUpdate(postId) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'reportCount',
        'moderationStatus',
        'lastReportedAt'
      ]) &&
      resource.data.visibilityStatus == 'visible' &&
      resource.data.moderationStatus == 'approved' &&
      request.resource.data.reportCount == resource.data.reportCount + 1 &&
      request.resource.data.lastReportedAt == request.time &&
      (
        (
          request.resource.data.reportCount >= 5 &&
          request.resource.data.moderationStatus == 'pending'
        ) ||
        (
          request.resource.data.reportCount < 5 &&
          request.resource.data.moderationStatus == resource.data.moderationStatus
        )
      ) &&
      !exists(reportDocPath(postId)) &&
      existsAfter(reportDocPath(postId));
    }

    function safeCommentCreate(postId, commentId) {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'id',
        'postId',
        'authorId',
        'authorDisplayName',
        'authorUsername',
        'authorPhotoUrl',
        'parentPostAuthorId',
        'parentPostPreview',
        'text',
        'likeCount',
        'reportCount',
        'visibilityStatus',
        'moderationStatus',
        'moderationReason',
        'moderatedBy',
        'moderatedAt',
        'lastReportedAt',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.id == commentId &&
      request.resource.data.postId == postId &&
      request.resource.data.authorId == request.auth.uid &&
      request.resource.data.likeCount == 0 &&
      request.resource.data.reportCount == 0 &&
      request.resource.data.visibilityStatus == 'visible' &&
      request.resource.data.moderationStatus == 'approved' &&
      request.resource.data.moderationReason == '' &&
      request.resource.data.moderatedBy == '' &&
      request.resource.data.moderatedAt == null &&
      request.resource.data.lastReportedAt == null &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time;
    }

    function safeCommentSoftDelete() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'visibilityStatus',
        'updatedAt'
      ]) &&
      resource.data.authorId == request.auth.uid &&
      request.resource.data.visibilityStatus == 'deleted' &&
      request.resource.data.updatedAt == request.time;
    }

    function safeCommentReportCounterUpdate(postId, commentId) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'reportCount',
        'moderationStatus',
        'lastReportedAt'
      ]) &&
      resource.data.visibilityStatus == 'visible' &&
      resource.data.moderationStatus == 'approved' &&
      request.resource.data.reportCount == resource.data.reportCount + 1 &&
      request.resource.data.lastReportedAt == request.time &&
      (
        (
          request.resource.data.reportCount >= 5 &&
          request.resource.data.moderationStatus == 'pending'
        ) ||
        (
          request.resource.data.reportCount < 5 &&
          request.resource.data.moderationStatus == resource.data.moderationStatus
        )
      ) &&
      !exists(/databases/$(database)/documents/socialPosts/$(postId)/comments/$(commentId)/reports/$(request.auth.uid)) &&
      existsAfter(/databases/$(database)/documents/socialPosts/$(postId)/comments/$(commentId)/reports/$(request.auth.uid));
    }

    function safeHashtagCreate(tag) {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'tag',
        'postCount',
        'recentPostIds',
        'lastUsedAt'
      ]) &&
      tag.matches('^[a-z0-9_]{1,30}$') &&
      request.resource.data.tag == tag &&
      request.resource.data.postCount == 1 &&
      request.resource.data.recentPostIds is list &&
      request.resource.data.recentPostIds.size() >= 1 &&
      request.resource.data.recentPostIds.size() <= 30 &&
      request.resource.data.lastUsedAt == request.time;
    }

    // TODO(nishant): Move hashtag mutation to Cloud Functions for stronger
    // append-only guarantees and duplicate prevention at scale.
    function safeHashtagUpdate(tag) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'tag',
        'postCount',
        'recentPostIds',
        'lastUsedAt'
      ]) &&
      tag.matches('^[a-z0-9_]{1,30}$') &&
      resource.data.tag == tag &&
      request.resource.data.tag == tag &&
      request.resource.data.postCount >= 1 &&
      request.resource.data.postCount == resource.data.postCount + 1 &&
      request.resource.data.recentPostIds is list &&
      request.resource.data.recentPostIds.size() >= 1 &&
      request.resource.data.recentPostIds.size() <= 30 &&
      request.resource.data.lastUsedAt == request.time;
    }

    function safeNotificationTokenCreate() {
      return request.resource.data.diff({}).changedKeys().hasOnly([
        'token',
        'createdAt',
        'updatedAt',
        'lastSeenAt',
        'platform'
      ]) &&
      request.resource.data.token is string &&
      request.resource.data.token.size() > 0 &&
      request.resource.data.platform is string &&
      request.resource.data.platform.size() > 0 &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.updatedAt == request.time &&
      request.resource.data.lastSeenAt == request.time;
    }

    function safeNotificationTokenUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'token',
        'updatedAt',
        'lastSeenAt',
        'platform'
      ]) &&
      request.resource.data.token is string &&
      request.resource.data.token.size() > 0 &&
      request.resource.data.platform is string &&
      request.resource.data.platform.size() > 0 &&
      request.resource.data.updatedAt == request.time &&
      request.resource.data.lastSeenAt == request.time &&
      request.resource.data.createdAt == resource.data.createdAt;
    }

    function validProviderVerificationDocKeys(data) {
      return data.keys().hasOnly([
        'userId',
        'status',
        'documentType',
        'documentFrontUrl',
        'documentBackUrl',
        'submittedAt',
        'reviewedAt',
        'reviewedBy',
        'rejectionReason',
        'firstServiceListedAt',
        'gracePeriodEndsAt',
        'createdAt',
        'updatedAt'
      ]);
    }

    function safeProviderVerificationOwnerWrite(userId) {
      return validProviderVerificationDocKeys(request.resource.data) &&
        request.resource.data.userId == userId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.documentType in ['aadhaar', 'drivingLicense', 'voterId'] &&
        request.resource.data.documentFrontUrl is string &&
        request.resource.data.documentFrontUrl.size() > 0 &&
        request.resource.data.documentBackUrl is string &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.reviewedBy == null &&
        (
          request.resource.data.rejectionReason == null ||
          request.resource.data.rejectionReason == ''
        ) &&
        (
          !request.resource.data.keys().hasAny(['firstServiceListedAt']) ||
          request.resource.data.firstServiceListedAt == null ||
          request.resource.data.firstServiceListedAt is timestamp
        ) &&
        (
          !request.resource.data.keys().hasAny(['gracePeriodEndsAt']) ||
          request.resource.data.gracePeriodEndsAt == null ||
          request.resource.data.gracePeriodEndsAt is timestamp
        ) &&
        request.resource.data.updatedAt == request.time;
    }

    function safeProviderVerificationOwnerCreate(userId) {
      return safeProviderVerificationOwnerWrite(userId) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.submittedAt == request.time;
    }

    function safeProviderVerificationOwnerUpdate(userId) {
      return safeProviderVerificationOwnerWrite(userId) &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.submittedAt == request.time &&
        resource.data.status != 'approved';
    }

    function safeProviderBankDetailsOwnerWrite(userId) {
      return request.resource.data.keys().hasOnly([
        'userId',
        'accountHolderName',
        'bankName',
        'accountNumberMasked',
        'ifscCode',
        'upiId',
        'status',
        'createdAt',
        'updatedAt'
      ]) &&
      request.resource.data.userId == userId &&
      request.resource.data.accountHolderName is string &&
      request.resource.data.accountHolderName.size() > 0 &&
      request.resource.data.bankName is string &&
      request.resource.data.bankName.size() > 0 &&
      request.resource.data.accountNumberMasked is string &&
      request.resource.data.accountNumberMasked.size() >= 4 &&
      request.resource.data.ifscCode is string &&
      request.resource.data.ifscCode.matches('^[A-Z]{4}0[A-Z0-9]{6}$') &&
      request.resource.data.upiId is string &&
      request.resource.data.status == 'submitted' &&
      request.resource.data.updatedAt == request.time;
    }

    function safeAdminSocialModerationUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'moderationStatus',
        'visibilityStatus',
        'moderationReason',
        'moderatedBy',
        'moderatedAt',
        'updatedAt'
      ]) &&
      request.resource.data.moderationStatus in ['approved', 'pending', 'rejected'] &&
      request.resource.data.visibilityStatus in ['visible', 'hidden', 'deleted'] &&
      request.resource.data.moderatedBy == request.auth.uid &&
      request.resource.data.moderatedAt == request.time &&
      request.resource.data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) &&
        request.resource.data.uid == userId &&
        safeUserOwnerCreate();
      allow update: if isOwner(userId) && safeUserOwnerUpdate();
      allow delete: if false;

      match /claimedOffers/{claimedOfferId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /notificationTokens/{tokenId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && safeNotificationTokenCreate();
        allow update: if isOwner(userId) && safeNotificationTokenUpdate();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /providerVerification/{docId} {
        // Owners may read only their own verification document. Support/admin
        // review is handled separately and does not grant public access.
        allow read: if isOwner(userId) || canReviewProviderVerification();
        allow create: if docId == 'main' &&
          isOwner(userId) &&
          safeProviderVerificationOwnerCreate(userId);
        allow update: if docId == 'main' &&
          (
            (isOwner(userId) && safeProviderVerificationOwnerUpdate(userId)) ||
            canReviewProviderVerification()
          );
        allow delete: if false;
      }

      match /providerBankDetails/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if docId == 'main' &&
          isOwner(userId) &&
          safeProviderBankDetailsOwnerWrite(userId) &&
          request.resource.data.createdAt == request.time;
        allow update: if docId == 'main' &&
          isOwner(userId) &&
          safeProviderBankDetailsOwnerWrite(userId) &&
          request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if false;
      }

      match /adminNotes/{noteId} {
        allow read, write: if isAdmin();
      }
    }

    // Collection group queries on providerVerification need an explicit
    // recursive matcher so Firestore can prove every matched document is
    // readable for the reviewing admin roles. This does not grant owners
    // access to other users' records, and client deletes remain blocked.
    match /{path=**}/providerVerification/{docId} {
      allow read: if canReviewProviderVerification();
      allow create, update, delete: if false;
    }

    match /userPrivate/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && safeUserPrivateOwnerCreate(userId);
      allow update: if isOwner(userId) && safeUserPrivateOwnerUpdate(userId);
      allow delete: if false;
    }

    match /offerCampaigns/{offerId} {
      allow read: if isAdmin() || (signedIn() && resource.data.isActive == true);
      allow create, update, delete: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn() &&
        (
          resource.data.followerId == request.auth.uid ||
          resource.data.followeeId == request.auth.uid
        );
      allow create: if signedIn() &&
        request.resource.data.diff({}).changedKeys().hasOnly([
          'followerId',
          'followeeId',
          'createdAt'
        ]) &&
        request.resource.data.followerId == request.auth.uid &&
        request.resource.data.followeeId is string &&
        request.resource.data.followeeId != request.auth.uid &&
        request.resource.id == (request.resource.data.followerId + '_' + request.resource.data.followeeId) &&
        request.resource.data.createdAt == request.time;
      allow delete: if signedIn() &&
        resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /hashtags/{tag} {
      allow read: if signedIn();
      allow create: if signedIn() && safeHashtagCreate(tag);
      allow update: if signedIn() && safeHashtagUpdate(tag);
      allow delete: if false;
    }

    match /socialPosts/{postId} {
      allow read: if canModerateSocialContent() || isAdmin() || (
        signedIn() &&
        (
          (
            resource.data.visibilityStatus == 'visible' &&
            resource.data.moderationStatus == 'approved'
          ) ||
          resource.data.authorId == request.auth.uid
        )
      );
      allow create: if signedIn() && safeSocialPostCreate();
      allow update: if signedIn() &&
        (
          (canModerateSocialContent() && safeAdminSocialModerationUpdate()) ||
          safeSocialPostSoftDelete() ||
          safeSocialPostLikeCounterUpdate(postId) ||
          safeSocialPostReportCounterUpdate(postId) ||
          safeSocialPostCommentCounterUpdate() ||
          safeSocialPostShareCounterUpdate()
        );
      allow delete: if false;

      match /likes/{userId} {
        allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if signedIn() &&
          request.auth.uid == userId &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.visibilityStatus == 'visible' &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.moderationStatus == 'approved' &&
          request.resource.data.diff({}).changedKeys().hasOnly([
            'userId',
            'createdAt'
          ]) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.createdAt == request.time;
        allow delete: if signedIn() &&
          request.auth.uid == userId &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.visibilityStatus == 'visible' &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.moderationStatus == 'approved';
        allow update: if false;
      }

      match /reports/{userId} {
        allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
        allow create: if signedIn() &&
          request.auth.uid == userId &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.visibilityStatus == 'visible' &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.moderationStatus == 'approved' &&
          request.resource.data.diff({}).changedKeys().hasOnly([
            'reporterId',
            'reason',
            'createdAt'
          ]) &&
          request.resource.data.reporterId == request.auth.uid &&
          request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /comments/{commentId} {
        allow read: if canModerateSocialContent() || isAdmin() || (
          signedIn() &&
          (
            (
              get(/databases/$(database)/documents/socialPosts/$(postId)).data.visibilityStatus == 'visible' &&
              get(/databases/$(database)/documents/socialPosts/$(postId)).data.moderationStatus == 'approved'
            ) ||
            resource.data.authorId == request.auth.uid
          )
        );
        allow create: if signedIn() &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.visibilityStatus == 'visible' &&
          get(/databases/$(database)/documents/socialPosts/$(postId)).data.moderationStatus == 'approved' &&
          safeCommentCreate(postId, commentId);
        allow update: if signedIn() &&
          (
            (canModerateSocialContent() && safeAdminSocialModerationUpdate()) ||
            safeCommentSoftDelete() ||
            safeCommentReportCounterUpdate(postId, commentId)
          );
        allow delete: if false;

        match /reports/{userId} {
          allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
          allow create: if signedIn() &&
            request.auth.uid == userId &&
            get(/databases/$(database)/documents/socialPosts/$(postId)/comments/$(commentId)).data.visibilityStatus == 'visible' &&
            get(/databases/$(database)/documents/socialPosts/$(postId)/comments/$(commentId)).data.moderationStatus == 'approved' &&
            request.resource.data.diff({}).changedKeys().hasOnly([
              'reporterId',
              'reason',
              'createdAt'
            ]) &&
            request.resource.data.reporterId == request.auth.uid &&
            request.resource.data.createdAt == request.time;
          allow update, delete: if false;
        }
      }
    }

    // Collection group queries for admin moderation need a path-agnostic
    // comments match. Keep this read-only and moderator-only so it does not
    // broaden normal user access.
    match /{path=**}/comments/{commentId} {
      allow read: if canModerateSocialContent();
    }

    match /services/{serviceId} {
      allow read: if isAdmin() || (
        signedIn() &&
        (resource.data.isDeleted != true) &&
        (
          resource.data.isVisibleToMarketplace == true ||
          resource.data.ownerUserId == request.auth.uid
        )
      );

      allow create: if signedIn() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.isDeleted == false &&
        request.resource.data.moderationStatus == 'pending' &&
        safeServiceOwnerCreate() &&
        safeServiceVerificationCreate(request.auth.uid);

      allow update: if isAdmin() ||
        (
          signedIn() &&
          existingOwnerId() == request.auth.uid &&
          request.resource.data.ownerUserId == resource.data.ownerUserId &&
          request.resource.data.moderationStatus == resource.data.moderationStatus &&
          safeServiceOwnerUpdate()
        );

      allow delete: if false;

      match /reviews/{reviewId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      match /slots/{slotId} {
        allow read: if signedIn() &&
          (
            get(/databases/$(database)/documents/services/$(serviceId)).data.isVisibleToMarketplace == true ||
            get(/databases/$(database)/documents/services/$(serviceId)).data.ownerUserId == request.auth.uid ||
            isAdmin()
          );

        // Slot creation, regeneration, acceptedCount, and capacity transitions
        // are server-owned so customers and providers cannot bypass capacity.
        allow create, update, delete: if isAdmin();
      }

      match /moderationEvents/{eventId} {
        allow read, write: if isAdmin();
      }
    }

    match /bookings/{bookingId} {
      allow read: if signedIn() &&
        (
          resource.data.customerId == request.auth.uid ||
          resource.data.serviceOwnerId == request.auth.uid ||
          isAdmin()
        );

      // Creation, status transitions, OTP verification, completion, and payout
      // changes are intentionally blocked for clients and handled by Cloud
      // Functions using the Admin SDK.
      allow create, update, delete: if isAdmin();

      match /events/{eventId} {
        allow read: if signedIn() &&
          (
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.serviceOwnerId == request.auth.uid ||
            isAdmin()
          );
        allow write: if isAdmin();
      }

      match /statusHistory/{historyId} {
        allow read: if signedIn() &&
          (
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.serviceOwnerId == request.auth.uid ||
            isAdmin()
          );
        allow write: if isAdmin();
      }

      match /messages/{messageId} {
        allow read, create: if signedIn() &&
          (
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
            get(/databases/$(database)/documents/bookings/$(bookingId)).data.serviceOwnerId == request.auth.uid ||
            isAdmin()
          );
        allow update, delete: if isAdmin();
      }
    }

    match /payoutReadiness/{bookingId} {
      allow read: if signedIn() &&
        (
          resource.data.providerId == request.auth.uid ||
          resource.data.customerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /bookingFinancials/{bookingId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /invoices/{invoiceId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /refunds/{refundId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /providerEarnings/{earningId} {
      allow read: if signedIn() &&
        (
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /payouts/{payoutId} {
      allow read: if signedIn() &&
        (
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin() ||
        (signedIn() &&
          (
            resource.data.reporterId == request.auth.uid ||
            resource.data.reportedBy == request.auth.uid
          )
        );
      allow create: if signedIn() &&
        request.resource.data.status == 'pending' &&
        (
          request.resource.data.reportedBy == request.auth.uid ||
          request.resource.data.reporterId == request.auth.uid
        );
      allow update, delete: if isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if signedIn() &&
        (
          resource.data.customerId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          (
            get(/databases/$(database)/documents/disputes/$(disputeId)).data.customerId == request.auth.uid ||
            get(/databases/$(database)/documents/disputes/$(disputeId)).data.providerId == request.auth.uid ||
            isAdmin()
          );
        allow create, update, delete: if false;
      }

      match /evidence/{evidenceId} {
        allow read: if signedIn() &&
          (
            get(/databases/$(database)/documents/disputes/$(disputeId)).data.customerId == request.auth.uid ||
            get(/databases/$(database)/documents/disputes/$(disputeId)).data.providerId == request.auth.uid ||
            isAdmin()
          );
        allow create, update, delete: if false;
      }
    }

    match /moderationQueue/{moderationItemId} {
      allow read, write: if isAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /chats/{chatId} {
      allow read: if chatParticipant(resource.data) || canMonitorChats();
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          (
            chatParticipant(
              get(/databases/$(database)/documents/chats/$(chatId)).data
            ) ||
            canMonitorChats()
          );
        allow create, update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'read',
          'isRead',
          'updatedAt'
        ]) &&
        request.resource.data.read == true &&
        request.resource.data.isRead == true &&
        request.resource.data.updatedAt == request.time;
      allow create, delete: if isAdmin();
    }
  }
}
